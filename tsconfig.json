{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "rootDir": "src",
    "outDir": "out",
    "sourceMap": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vscode", "react", "react-dom"],
    "jsx": "react-jsx"
  },
  "exclude": [
    "node_modules",
    "test",
    ".vscode-test",
    "out-test",
    "vite.config.ts",
    "src/panels/buildCompare/webview/**",
    "src/panels/buildDetails/webview/**",
    "src/panels/nodeCapacity/webview/**",
    "src/panels/nodeDetails/webview/**",
    "src/panels/shared/webview/components/**",
    "src/panels/shared/webview/icons/**",
    "src/panels/shared/webview/lib/**"
  ]
}
